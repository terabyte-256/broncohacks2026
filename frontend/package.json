"eslint": "^10.2.0",
"eslint-plugin-svelte": "^3.17.0",
"globals": "^17.4.0",
"playwright": "^1.59.1",
"svelte": "^5.55.2",
"svelte-check": "^4.4.6",
"tailwindcss": "^4.2.2",
"typescript": "^6.0.2",
